__require_commands chezmoi git __uppkg || return 1

# Use a subshell to keep strict mode and locals scoped to this command.
(
    set -eo pipefail

    local _source_path
    _source_path=$(chezmoi source-path)

    if [[ -n "$(git -C "${_source_path}" status --porcelain)" ]]; then
        echo_failure "chezmoi source repo has uncommitted changes\n"
        git -C "${_source_path}" status --short >&2
        exit 1
    fi

    local _chezmoi_status
    _chezmoi_status=$(chezmoi status)
    if [[ -n "${_chezmoi_status}" ]]; then
        echo_failure "chezmoi has unapplied differences\n"
        printf "%s\n" "${_chezmoi_status}" >&2
        exit 1
    fi

    chezmoi update

    __uppkg

    local _ahead
    _ahead=$(git -C "${_source_path}" rev-list --count @{upstream}..HEAD 2>/dev/null || printf "0")
    if (( _ahead > 0 )); then
        git -C "${_source_path}" push
    fi

    chezmoi apply
)
