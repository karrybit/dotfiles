#!/bin/zsh

if [[ -z "$TMUX" ]]; then
    exec tmux -f "${XDG_CONFIG_HOME:-$HOME/.config}/tmux/tmux.conf" new-session -A -s main
fi

# theme
case "${OSTYPE}" in
darwin*)
    zstyle ':completion:*' matcher-list '' 'm:{[:lower:]}={[:upper:]}' '+m:{[:upper:]}={[:lower:]}'
    ;;
linux*)
    # Use powerline
    USE_POWERLINE="true"
    # Source manjaro-zsh-configuration
    if [[ -e /usr/share/zsh/manjaro-zsh-config ]]; then
        source /usr/share/zsh/manjaro-zsh-config
    fi
    # Use manjaro zsh prompt
    if [[ -e /usr/share/zsh/manjaro-zsh-prompt ]]; then
        source /usr/share/zsh/manjaro-zsh-prompt
    fi
    ;;
esac

source "$ZDOTDIR/abbreviations.zsh"

# git
zstyle ':completion:*:*:git:*' script "$ZDOTDIR/completions/git-completion.bash"
autoload -Uz compinit && compinit -u

# port_forward.zsh は手動で ~/.config/zsh/ に配置する（chezmoi管理外）
[[ -f "$XDG_CONFIG_HOME/zsh/port_forward.zsh" ]] && \
    source "$XDG_CONFIG_HOME/zsh/port_forward.zsh"

# direnv
eval "$(direnv hook zsh)"

# kube
[[ -d ~/.kube ]] && source <(kubectl completion zsh)

autoload -U +X bashcompinit && bashcompinit
(( $+commands[terraform] )) && complete -o nospace -C "$(command -v terraform)" terraform

## history
setopt hist_expire_dups_first
setopt hist_ignore_all_dups
setopt hist_ignore_dups
setopt hist_save_no_dups
setopt share_history

## prompt
eval "$(starship init zsh)"

# Docker completions
fpath=("$HOME/.docker/completions" $fpath)

# antidote (nix managed — home.file symlink to nix store)
source "${XDG_DATA_HOME:-$HOME/.local/share}/antidote/antidote.zsh"
antidote load "$ZDOTDIR/.zsh_plugins.txt"
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down

source "$XDG_CONFIG_HOME/zsh/lib/ui.zsh"
source "$XDG_CONFIG_HOME/zsh/lib/fzf.zsh"

fpath=("$XDG_CONFIG_HOME/zsh/functions" $fpath)
autoload -Uz "$XDG_CONFIG_HOME/zsh/functions/"*(N.)

fpath=("$XDG_CONFIG_HOME/zsh/widgets" $fpath)
autoload -Uz "$XDG_CONFIG_HOME/zsh/widgets/"*(N.)

case "${OSTYPE}" in
darwin*)
    fpath=("$XDG_CONFIG_HOME/zsh/functions/darwin" $fpath)
    autoload -Uz "$XDG_CONFIG_HOME/zsh/functions/darwin/"*(N.)
    ;;
linux*)
    fpath=("$XDG_CONFIG_HOME/zsh/functions/linux" $fpath)
    autoload -Uz "$XDG_CONFIG_HOME/zsh/functions/linux/"*(N.)
    ;;
esac

zle -N __select_history_with_fzf
bindkey '^r' __select_history_with_fzf

# Interactive init for manually installed tools (gcloud, SDKMAN, etc.)
for f in "$ZDOTDIR/env.d/"*.zsh(N); do source "$f"; done

# Ensure Nix takes precedence after shell integration (VS Code etc.) rewrites PATH
path=(
  $HOME/.nix-profile/bin
  /etc/profiles/per-user/$USER/bin
  /run/current-system/sw/bin
  /nix/var/nix/profiles/default/bin
  /opt/homebrew/bin
  /opt/homebrew/sbin
  $path
)
typeset -U path
