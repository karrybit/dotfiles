// Claude Code settings shared by all local profiles.
// Keep company-specific providers, plugin marketplaces, and credentials in
// $XDG_CONFIG_HOME/claude/settings.work.pkl instead.

settings: Dynamic = new Dynamic {
  env {
    ["ANTHROPIC_MODEL"] = "claude-sonnet-4-6"
    ["ANTHROPIC_DEFAULT_OPUS_MODEL"] = "claude-opus-4-8"
    ["ANTHROPIC_DEFAULT_SONNET_MODEL"] = "claude-sonnet-4-6"
    ["ANTHROPIC_DEFAULT_HAIKU_MODEL"] = "claude-haiku-4-5@20251001"
    ["CLAUDE_CODE_SESSIONEND_HOOKS_TIMEOUT_MS"] = "60000"
    ["ENABLE_TOOL_SEARCH"] = "true"
  }
  permissions {
    defaultMode = "default"
    allow {
      "Read(~/.local/share/go/*)"
      "Read(~/work/*)"
    }
    deny {
      "Read(./.env)"
      "Read(./.env.*)"
      "Read(./secrets/**)"
      "Read(./config/credentials.json)"
      "Read(~/.ssh/**)"
      "Read(~/.aws/**)"
      "Read(~/.config/gcloud/**)"
      "Read(~/.kube/**)"
    }
    disableBypassPermissionsMode = "disable"
  }
  sandbox {
    enabled = true
    autoAllowBashIfSandboxed = false
    excludedCommands {
      "docker *"
    }
    network {
      allowedDomains {
        "github.com"
        "api.github.com"
        "raw.githubusercontent.com"
        "objects.githubusercontent.com"
        "*.githubusercontent.com"
        "registry.npmjs.org"
        "*.npmjs.org"
        "registry.yarnpkg.com"
        "pypi.org"
        "files.pythonhosted.org"
        "crates.io"
        "static.crates.io"
        "index.crates.io"
      }
    }
  }
  worktree {
    baseRef = "head"
  }
  statusLine {
    type = "command"
    command = "~/.config/claude/statusline.sh"
    refreshInterval = 5
  }
  enabledPlugins {
    ["usage-collector@awesome-claude-marketplace"] = false
    ["skill-creator@claude-plugins-official"] = true
    ["slack@claude-plugins-official"] = true
    ["superpowers@claude-plugins-official"] = true
    ["gopls-lsp@claude-plugins-official"] = true
    ["typescript-lsp@claude-plugins-official"] = true
  }
  alwaysThinkingEnabled = true
  effortLevel = "xhigh"
  autoUpdatesChannel = "stable"
  hooks {
    ["PostToolUse"] = new Listing {
      new Dynamic {
        matcher = "Edit|Write|MultiEdit"
        hooks = new Listing {
          new Dynamic {
            type = "command"
            command = "git diff --check"
          }
        }
      }
    }
    ["Stop"] = new Listing {
      new Dynamic {
        hooks = new Listing {
          new Dynamic {
            type = "command"
            command = #"osascript -e 'display notification "Claude Code finished" with title "Claude"' 2>/dev/null; afplay /System/Library/Sounds/Glass.aiff 2>/dev/null; true"#
          }
        }
      }
    }
    ["PreCompact"] = new Listing {
      new Dynamic {
        hooks = new Listing {
          new Dynamic {
            type = "command"
            command = "true"
          }
        }
      }
    }
  }
}

output {
  value = settings
  renderer = new JsonRenderer {}
}
